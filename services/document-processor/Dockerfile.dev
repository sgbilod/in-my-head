FROM python:3.12-slim AS development

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
# Use lightweight requirements for Docker
COPY requirements.docker.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY . .

# Expose port (8002 — ai-engine owns 8001)
EXPOSE 8002

# Development command (src.app = parse-and-forward service; src.main is legacy)
CMD ["uvicorn", "src.app:app", "--reload", "--host", "0.0.0.0", "--port", "8002"]
