# In My Head - Environment Variables Template
# ============================================
# ⚠️  IMPORTANT: This is a template file
# Copy this to .env and fill in your actual values
# NEVER commit the .env file to Git!

# ====================
# AI Service API Keys
# ====================

# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API Key (for embeddings and fallback)
# Get from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=your_openai_key_here

# ====================
# Database Credentials
# ====================

# PostgreSQL Database
POSTGRES_USER=inmyhead_user
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=inmyhead_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ====================
# Redis Cache
# ====================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ====================
# Qdrant Vector Database
# ====================

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change_this_qdrant_key

# ====================
# MinIO Object Storage
# ====================

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=inmyhead-documents

# ====================
# Application Settings
# ====================

# Environment (development, production)
ENVIRONMENT=development

# API Base URL
API_BASE_URL=http://localhost:8001

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ====================
# Security Settings
# ====================

# JWT Secret for authentication (if implemented)
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# Session Secret
SESSION_SECRET=change_this_session_secret_min_32_chars

# ====================
# Optional Services
# ====================

# GitHub Personal Access Token (for resource manager)
# GITHUB_TOKEN=ghp_...

# Monitoring and Analytics
# SENTRY_DSN=https://...

# ====================
# Notes
# ====================

# 1. Generate secure passwords:
#    - PowerShell: -join ((33..126) | Get-Random -Count 32 | ForEach-Object {[char]$_})
#    - Online: https://www.random.org/passwords/ (save offline!)
#
# 2. Store this file securely:
#    - Use a password manager (1Password, LastPass, Bitwarden)
#    - Keep backup on encrypted USB drive
#    - NEVER commit to Git or share publicly
#
# 3. Rotate credentials regularly:
#    - API keys: Every 90 days
#    - Database passwords: Every 180 days
#    - Check for unauthorized access monthly
